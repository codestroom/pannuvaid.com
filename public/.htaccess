# ---------------------------------------------------------------------
# Pannu Vaid — static Next.js export on Hostinger (Apache shared hosting)
# ---------------------------------------------------------------------

# --- Security headers (mirrors the old vercel.json) ---
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# --- Clean URLs: serve /about from about.html, etc. ---
<IfModule mod_rewrite.c>
  RewriteEngine On

  # If a request maps to an existing file or directory, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Try "<path>.html" for extensionless requests (e.g. /about -> about.html)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # Custom 404 fallback
  ErrorDocument 404 /404.html
</IfModule>

# --- Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# --- Caching ---
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed Next.js assets are immutable — cache hard
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images
  <FilesMatch "\.(png|jpe?g|gif|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML should always be revalidated so updates show immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
